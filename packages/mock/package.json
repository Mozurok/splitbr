{
  "name": "@splitbr/mock",
  "version": "0.1.0",
  "description": "Mock local da Plataforma Publica do Split Payment (IBS/CBS, LC 214/2025) para desenvolvimento e testes de PSPs",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "data",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@splitbr/client": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.10.0"
  },
  "bin": {
    "splitbr-mock": "./bin/splitbr-mock.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mozurok/splitbr.git",
    "directory": "packages/mock"
  },
  "homepage": "https://github.com/Mozurok/splitbr/tree/main/packages/mock#readme",
  "bugs": {
    "url": "https://github.com/Mozurok/splitbr/issues"
  },
  "keywords": [
    "split-payment",
    "reforma-tributaria",
    "ibs",
    "cbs",
    "lc-214",
    "pix",
    "boleto",
    "psp",
    "brasil"
  ],
  "publishConfig": {
    "access": "public"
  }
}
